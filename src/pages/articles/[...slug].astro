---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<BlogLayout title={article.data.title} description={article.data.summary}>
  <article class="article-wrapper">
    <!-- Article header -->
    <header class="article-header">
      <div class="header-inner">
        <div class="header-meta">
          <span class="mono header-date">{article.data.date}</span>
          <div class="header-tags">
            {article.data.tags.map((tag: string) => (
              <span class="header-tag">#{tag}</span>
            ))}
          </div>
        </div>
        <h1>{article.data.title}</h1>
        {article.data.subtitle && <p class="article-subtitle">{article.data.subtitle}</p>}
        <p class="article-summary">{article.data.summary}</p>
        <p class="article-author mono">By {article.data.author}</p>
      </div>
    </header>

    <!-- Article body (MDX renders here) -->
    <div class="article-body">
      <Content />
    </div>
  </article>
</BlogLayout>

<style>
.article-wrapper {
  padding-top: 56px;
}

.article-header {
  border-bottom: 1px solid var(--border);
  padding: 5rem 2rem 4rem;
}

.header-inner {
  max-width: 760px;
  margin: 0 auto;
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.header-date {
  font-size: 0.78rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
}

.header-tags {
  display: flex;
  gap: 1rem;
}

.header-tag {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--fire);
  letter-spacing: 0.04em;
}

.article-header h1 {
  margin-bottom: 1rem;
  color: var(--text);
}

.article-subtitle {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.2rem;
  color: var(--text-muted);
  margin-bottom: 1rem;
  font-weight: 300;
}

.article-summary {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.75;
  max-width: 580px;
  margin-bottom: 1.5rem;
}

.article-author {
  font-size: 0.78rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

/* Prose styles for MDX body */
.article-body {
  max-width: 100%;
}

/* Full-width scrolly sections inside body */
.article-body :global(.scrolly-full) {
  width: 100%;
  max-width: 100%;
}

/* Constrained prose sections */
.article-body :global(p),
.article-body :global(h2),
.article-body :global(h3),
.article-body :global(ul),
.article-body :global(ol),
.article-body :global(blockquote),
.article-body :global(pre) {
  max-width: 720px;
  margin-left: auto;
  margin-right: auto;
  padding-left: 2rem;
  padding-right: 2rem;
}

.article-body :global(p) {
  margin-bottom: 1.5rem;
  color: var(--text-muted);
  font-size: 1.02rem;
  line-height: 1.8;
}

.article-body :global(h2) {
  color: var(--text);
  margin: 4rem auto 1.5rem;
  font-size: 1.7rem;
}

.article-body :global(h3) {
  color: var(--text);
  margin: 3rem auto 1rem;
  font-size: 1.15rem;
}

.article-body :global(strong) { color: var(--text); }

.article-body :global(blockquote) {
  border-left: 2px solid var(--fire);
  padding-left: 1.5rem !important;
  color: var(--text-muted);
  font-style: italic;
  font-family: var(--font-display);
  font-size: 1.1rem;
}

.article-body :global(code) {
  font-family: var(--font-mono);
  font-size: 0.85em;
  background: var(--bg-3);
  color: var(--teal);
  padding: 0.15em 0.4em;
  border-radius: 4px;
}
</style>
