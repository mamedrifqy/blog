---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const tagColorMap: Record<string, string> = {
  fire: 'fire', peatland: 'fire', ENSO: 'ml', 'machine-learning': 'ml',
  SAR: 'sar', 'remote-sensing': 'remote-sensing',
};

// Categories for topic filter
const allTopics = ['All', 'Peatland', 'Mangrove', 'Remote Sensing', 'Machine Learning', 'Deforestation'];
---

<BaseLayout title="Stories" activePage="home">

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="home-hero">
    <div class="hero-bg-lines" aria-hidden="true">
      {Array.from({length: 10}).map((_, i) => (
        <div class="bg-line" style={`--i:${i}`} />
      ))}
    </div>

    <div class="hero-content container">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>Geospatial Storytelling · Southeast Asia</span>
      </div>

      <h1 class="hero-headline">
        Maps that<br/>
        <em>tell the story.</em>
      </h1>

      <p class="hero-body">
        Spatial analysis, remote sensing, and data-driven narratives
        on fire, deforestation, coastal ecosystems, and disaster risk
        across Indonesia and Southeast Asia.
      </p>

      <div class="hero-stats">
        <div class="hstat">
          <span class="hstat-n">3</span>
          <span class="hstat-l">Published analyses</span>
        </div>
        <div class="hstat-sep"></div>
        <div class="hstat">
          <span class="hstat-n">11</span>
          <span class="hstat-l">Kecamatan mapped</span>
        </div>
        <div class="hstat-sep"></div>
        <div class="hstat">
          <span class="hstat-n">10yr</span>
          <span class="hstat-l">Satellite record</span>
        </div>
        <div class="hstat-sep"></div>
        <div class="hstat">
          <span class="hstat-n">S2</span>
          <span class="hstat-l">Thesis · UNRI</span>
        </div>
      </div>
    </div>

    <!-- Scrolling ticker — like a newsroom dateline -->
    <div class="hero-ticker">
      <div class="ticker-track">
        <span>MODIS/VIIRS · Fire Detection</span>
        <span>·</span>
        <span>Sentinel-1 SAR · Mangrove Suitability</span>
        <span>·</span>
        <span>XGBoost · SHAP Attribution</span>
        <span>·</span>
        <span>ENSO Teleconnection · Bengkalis</span>
        <span>·</span>
        <span>Google Earth Engine · CHIRPS · ERA5-Land</span>
        <span>·</span>
        <span>Riau Province · Indonesia</span>
        <span>·</span>
        <span>MODIS/VIIRS · Fire Detection</span>
        <span>·</span>
        <span>Sentinel-1 SAR · Mangrove Suitability</span>
        <span>·</span>
        <span>XGBoost · SHAP Attribution</span>
        <span>·</span>
      </div>
    </div>
  </section>

  <!-- ── Featured / Latest ─────────────────────────────────── -->
  <section class="stories-section">
    <div class="container">

      <div class="section-header">
        <div class="section-label">
          <span class="label-line"></span>
          <span>Latest stories</span>
        </div>
      </div>

      <!-- Feature card — first article -->
      {articles[0] && (
        <a href={`/blog/${articles[0].slug}`} class="feature-card">
          <div class="feature-meta">
            <div class="feature-tags">
              {articles[0].data.tags.map(tag => (
                <span class={`tag ${tagColorMap[tag] ?? ''}`}>{tag}</span>
              ))}
            </div>
            <time class="feature-date">
              {new Date(articles[0].data.date).toLocaleDateString('en-GB', {year:'numeric',month:'short',day:'numeric'})}
            </time>
          </div>
          <h2 class="feature-title">{articles[0].data.title}</h2>
          {articles[0].data.subtitle && (
            <p class="feature-sub">{articles[0].data.subtitle}</p>
          )}
          <div class="feature-cta">
            Read analysis <span class="cta-arrow">→</span>
          </div>
        </a>
      )}

      <!-- Grid of remaining articles -->
      {articles.length > 1 && (
        <div class="articles-grid">
          {articles.slice(1).map(article => (
            <a href={`/${article.slug}`} class="article-card">
              <div class="card-tags">
                {article.data.tags.slice(0,2).map(tag => (
                  <span class={`tag ${tagColorMap[tag] ?? ''}`}>{tag}</span>
                ))}
              </div>
              <h3 class="card-title">{article.data.title}</h3>
              {article.data.subtitle && (
                <p class="card-sub">{article.data.subtitle}</p>
              )}
              <div class="card-footer">
                <time>{new Date(article.data.date).toLocaleDateString('en-GB',{year:'numeric',month:'short'})}</time>
                <span class="card-read">Read →</span>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- ── About strip ───────────────────────────────────────── -->
  <section class="about-strip container">
    <div class="strip-inner">
      <div class="strip-text">
        <div class="section-label">
          <span class="label-line"></span>
          <span>About this project</span>
        </div>
        <p>
          <strong>medrifmaps</strong> is the geospatial research portfolio of mamed/rifqy —
          a geospatial analyst based in Riau Province, Indonesia, pursuing an S2 in
          Disaster Management at Universitas Riau. The work spans peatland fire
          analysis, mangrove rehabilitation mapping, and machine learning for
          disaster risk reduction.
        </p>
        <a href="/about" class="strip-link">Learn more about the project →</a>
      </div>
      <div class="strip-tools">
        <div class="tools-label">Tools & data sources</div>
        <div class="tools-grid">
          {['Google Earth Engine','MODIS / VIIRS','Sentinel-1 SAR','Sentinel-2','CHIRPS v2.0','ERA5-Land','Hansen GFC','XGBoost / SHAP','MapLibre GL JS'].map(t => (
            <div class="tool-chip">{t}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ──────────────────────────────────────────────────── */
.home-hero {
  position: relative;
  min-height: 88vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: calc(var(--nav-h) + 5rem);
  overflow: hidden;
}

/* Vertical grid lines background */
.hero-bg-lines {
  position: absolute; inset: 0; z-index: 0;
  display: flex; justify-content: space-evenly;
  pointer-events: none;
}
.bg-line {
  width: 1px;
  background: linear-gradient(to bottom,
    transparent 0%,
    rgba(28,200,170,calc(0.025 + var(--i) * 0.005)) 30%,
    rgba(28,200,170,calc(0.025 + var(--i) * 0.005)) 70%,
    transparent 100%
  );
}

.hero-content { position: relative; z-index: 2; padding-bottom: 4rem; }

.hero-eyebrow {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--teal);
  margin-bottom: 2rem;
}
.eyebrow-dot {
  width: 6px; height: 6px;
  background: var(--teal); border-radius: 50%;
  box-shadow: 0 0 8px var(--teal);
}

.hero-headline {
  font-size: clamp(3rem, 8vw, 6rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.0;
  margin-bottom: 1.5rem;
  color: var(--text-bright);
}
.hero-headline em {
  font-style: italic;
  color: var(--teal);
}

.hero-body {
  font-size: 1.1rem; font-weight: 400;
  color: var(--text-muted); line-height: 1.65;
  max-width: 520px; margin-bottom: 3rem;
}

.hero-stats {
  display: flex; align-items: center; gap: 0; flex-wrap: wrap;
  padding: 1.5rem 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.hstat { padding: 0 2rem 0 0; }
.hstat:first-child { padding-left: 0; }
.hstat-n { display: block; font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--text-bright); line-height: 1; }
.hstat-l { display: block; font-size: 0.72rem; color: var(--text-dim); margin-top: 0.2rem; letter-spacing: 0.04em; }
.hstat-sep { width: 1px; height: 36px; background: var(--border); margin: 0 2rem 0 0; }

/* Ticker */
.hero-ticker {
  position: relative; z-index: 2;
  background: var(--bg-card);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  overflow: hidden; padding: 0.65rem 0;
}
.ticker-track {
  display: flex; gap: 2rem; align-items: center;
  white-space: nowrap;
  animation: ticker 30s linear infinite;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--text-dim);
  width: max-content;
}
.ticker-track span { flex-shrink: 0; }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ── Stories section ───────────────────────────────────────── */
.stories-section { padding: 5rem 0 4rem; }

.section-header { margin-bottom: 2rem; }
.section-label {
  display: flex; align-items: center; gap: 0.75rem;
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--text-dim);
}
.label-line { width: 24px; height: 1px; background: var(--teal); }

/* Feature card */
.feature-card {
  display: block;
  padding: 2.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 4px solid var(--teal);
  border-radius: 6px;
  text-decoration: none;
  margin-bottom: 1.5px;
  transition: background 0.2s, border-left-color 0.2s;
}
.feature-card:hover { background: var(--bg-hover); border-left-color: var(--gold); }

.feature-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
.feature-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.feature-date { font-size: 0.78rem; color: var(--text-dim); }

.feature-title {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 3vw, 2rem);
  color: var(--text-bright); line-height: 1.2;
  margin: 0 0 0.75rem; letter-spacing: -0.01em;
}

.feature-sub { font-size: 0.95rem; color: var(--text-muted); max-width: 620px; line-height: 1.6; margin-bottom: 1.5rem; }

.feature-cta {
  font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em;
  text-transform: uppercase; color: var(--teal); display: flex; align-items: center; gap: 0.4rem;
}
.cta-arrow { transition: transform 0.2s; }
.feature-card:hover .cta-arrow { transform: translateX(4px); }

/* Grid cards */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5px;
  margin-top: 1.5px;
}

.article-card {
  display: flex; flex-direction: column;
  padding: 1.75rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  text-decoration: none;
  transition: background 0.2s;
  border-radius: 4px;
}
.article-card:hover { background: var(--bg-hover); }
.card-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 0.75rem; }

.card-title {
  font-family: var(--font-display);
  font-size: 1.15rem; color: var(--text-bright);
  line-height: 1.25; margin: 0 0 0.5rem;
}

.card-sub { font-size: 0.85rem; color: var(--text-muted); line-height: 1.55; flex: 1; margin: 0 0 1rem; }

.card-footer {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 0.78rem; color: var(--text-dim);
  padding-top: 0.75rem; border-top: 1px solid var(--border);
  margin-top: auto;
}
.card-read { color: var(--teal); font-weight: 600; }
.article-card:hover .card-read { color: var(--gold); }

/* ── About strip ───────────────────────────────────────────── */
.about-strip { padding: 4rem 0 5rem; }
.strip-inner {
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
}
.strip-text .section-label { margin-bottom: 1.25rem; }
.strip-text p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 1rem; }
.strip-link { font-size: 0.85rem; font-weight: 700; color: var(--teal); letter-spacing: 0.02em; }
.strip-link:hover { color: var(--gold); }

.tools-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 1rem; }
.tools-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.tool-chip {
  font-size: 0.75rem; font-weight: 600;
  color: var(--text-muted);
  border: 1px solid var(--border);
  padding: 0.3em 0.75em; border-radius: 3px;
  background: var(--bg-card);
  transition: border-color 0.15s, color 0.15s;
}
.tool-chip:hover { border-color: var(--teal); color: var(--teal); }

@media (max-width: 768px) {
  .strip-inner { grid-template-columns: 1fr; gap: 2rem; }
  .hero-stats { gap: 1rem; }
  .hstat-sep { display: none; }
  .hstat { padding: 0 1rem 0 0; }
}
</style>
